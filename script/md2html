#!/bin/bash

if [ $# -eq 0 ]; then
  pages=$(cd sitewiki && find . -name "*.md" | sed 's|^\./||; s|\.md$||')
else
  pages=$1
fi

for page in $pages;
do
  echo "Converting: $page"

  # If a subdirectory exists for this page, output to page/index.html
  if [ -d "sitewiki/$page" ]; then
    outfile="docs/$page/index.html"
    depth=$(echo "$page/" | tr -cd '/' | wc -c | tr -d ' ')
  else
    outfile="docs/$page.html"
    depth=$(echo "$page" | tr -cd '/' | wc -c | tr -d ' ')
  fi

  prefix=""
  for ((i=0; i<depth; i++)); do prefix="../$prefix"; done

  mkdir -p "$(dirname "$outfile")"

  tmpl=$(sed "s|href=\"static/|href=\"${prefix}static/|g; s|src=\"static/|src=\"${prefix}static/|g; s|src=\"js/|src=\"${prefix}js/|g; s|PAGE_NAME|${page}|g" docs/static/template)

  printf '%s\n' "$tmpl" | awk '/<!-- Begin page-specific html -->/{print; exit} {print}' > "$outfile"
  if [ -d "sitewiki/$page" ]; then
    base=$(basename "$page")
    pandoc --lua-filter=script/links-to-html.lua -M "strip-prefix=${base}/" "sitewiki/$page.md" | sed 's/ type="1"//g' >> "$outfile"
  else
    pandoc --lua-filter=script/links-to-html.lua "sitewiki/$page.md" | sed 's/ type="1"//g' >> "$outfile"
  fi
  printf '%s\n' "$tmpl" | awk '/<!-- Begin page-specific html -->/{found=1; next} found{print}' >> "$outfile"
  tidy -iqm -w 80 --tidy-mark no "$outfile"
done
